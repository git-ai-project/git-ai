digraph rebase_v3_ideal {
    rankdir=TB;
    compound=true;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", fillcolor="#f9f9f9"];
    edge [fontname="Helvetica", fontsize=8];

    // =============================================
    // CLI ENTRY POINTS (unchanged)
    // =============================================
    subgraph cluster_entry {
        label="CLI Entry Points (src/main.rs)";
        style=filled;
        fillcolor="#e8f4fd";

        main [label="main()\nargv[0] dispatch", shape=diamond, fillcolor="#bbdefb"];
        git_proxy_mode [label="argv[0] == \"git\"\n(production symlink)", fillcolor="#c8e6c9"];
        debug_env [label="GIT_AI=git env var\n(debug builds only)", fillcolor="#fff9c4", style="rounded,filled,dashed"];
    }

    main -> git_proxy_mode [label="argv[0]=git"];
    main -> debug_env [label="debug && GIT_AI=git"];
    debug_env -> git_proxy_mode;

    // =============================================
    // GIT PROXY (unchanged from current)
    // =============================================
    subgraph cluster_wrapper {
        label="Git Proxy (src/commands/git_handlers.rs)";
        style=filled;
        fillcolor="#f3e5f5";

        handle_git [label="handle_git(args)"];
        send_pre [label="send_wrapper_pre_state_to_daemon()\n{invocation_id, worktree, head}"];
        proxy_to_git [label="proxy_to_git(args)\n→ real git (signal forwarding)"];
        send_post [label="send_wrapper_post_state_to_daemon()\n{invocation_id, worktree, head}"];
    }

    git_proxy_mode -> handle_git;
    handle_git -> send_pre [label="mutating cmd\n+ daemon connected"];
    send_pre -> proxy_to_git;
    proxy_to_git -> send_post;

    // =============================================
    // DAEMON (trace + normalize unchanged)
    // =============================================
    subgraph cluster_daemon {
        label="Daemon — Background Process";
        style=filled;
        fillcolor="#fff3e0";

        trace_ingest [label="Trace2 Ingest\n+ Normalizer\n→ NormalizedCommand"];
        wrapper_overlay [label="apply_wrapper_state_overlay()\n(merge pre/post from wrapper)"];
        side_effects [label="maybe_apply_side_effects_for_applied_command()\n\nNO conflict tracking.\nNO pending state.\nNO rewrite_log.\nOnly processes FINAL state."];
    }

    send_pre -> trace_ingest [style=dotted, color=blue, label="IPC"];
    send_post -> trace_ingest [style=dotted, color=blue, label="IPC"];
    proxy_to_git -> trace_ingest [style=dotted, color=blue, label="GIT_TRACE2"];
    trace_ingest -> wrapper_overlay;
    wrapper_overlay -> side_effects;

    // =============================================
    // SEMANTIC EVENT → TRIPLE DETECTION
    // All sources produce the same (onto, original, new) triple
    // =============================================
    subgraph cluster_event_detection {
        label="detect_rewrite_triple_from_event()\n→ Option<RewriteTriple>";
        style=filled;
        fillcolor="#e8f5e9";

        detect_rewrite [label="detect_rewrite_triple()", fillcolor="#c8e6c9"];

        subgraph cluster_sources {
            label="Event Sources (SemanticEvent variants)";
            style=filled;
            fillcolor="#c8e6c9";

            src_rebase [label="RebaseComplete\n{old_head, new_head}"];
            src_pull_rebase [label="PullCompleted\n{strategy: Rebase}"];
            src_cherry_pick [label="CherryPickComplete\n{original_head, new_head}"];
            src_amend [label="CommitAmended\n{old_head, new_head}"];
            src_reset [label="Reset (non-ancestor)\n{old_head, new_head}"];
            src_ref_update [label="RefUpdated\n{old, new} (non-ancestor)"];
            src_merge_squash [label="MergeSquash\n{base_head, source_head}\n\nSource reconstructed from\ngit state (SQUASH_MSG,\nreflog) — fully stateless"];
        }

        triple [label="RewriteTriple {\n  onto: CommitId,\n  original_head: CommitId,\n  new_head: CommitId\n}", shape=note, fillcolor="#a5d6a7"];

        onto_resolution [label="onto = merge_base(original, new)\nor parent(old) for amend", fillcolor="#e8f5e9"];
    }

    side_effects -> detect_rewrite;
    src_rebase -> detect_rewrite;
    src_pull_rebase -> detect_rewrite;
    src_cherry_pick -> detect_rewrite;
    src_amend -> detect_rewrite;
    src_reset -> detect_rewrite;
    src_ref_update -> detect_rewrite;
    src_merge_squash -> detect_rewrite;
    detect_rewrite -> onto_resolution;
    onto_resolution -> triple;

    // =============================================
    // STASH (separate path — not a rewrite op)
    // =============================================
    subgraph cluster_stash {
        label="Stash Attribution (separate, NOT a rewrite op)";
        style=filled;
        fillcolor="#fafafa";

        stash_event [label="StashOperation event\n(from trace2 ref-changes)\nSHA available in same\nside-effect pass"];
        stash_save [label="save_stash_authorship_log()\n(git notes on stash SHA)"];
        stash_restore [label="restore_stash_attributions()\n(read notes, apply to workdir)"];
    }

    side_effects -> stash_event [label="stash op"];
    stash_event -> stash_save [label="Create"];
    stash_event -> stash_restore [label="Pop/Apply"];

    // =============================================
    // ===== UNIFIED REWRITE HANDLER v3 =====
    // =============================================
    subgraph cluster_v3 {
        label="handle_rewrite_op_v3() — SINGLE FUNCTION FOR ALL REWRITES\nsrc/authorship/rewrite_op_v3.rs (~400 lines)";
        style="filled,bold";
        fillcolor="#e3f2fd";
        color="#1565c0";
        penwidth=2;

        v3_entry [label="handle_rewrite_op_v3(\n  repo,\n  triple: RewriteTriple\n)", fillcolor="#90caf9", style="rounded,filled,bold"];

        // =============================================
        // STEP 1: RANGE-DIFF (commit mapping)
        // =============================================
        subgraph cluster_range_diff {
            label="Step 1: git range-diff (src/git/range_diff.rs)";
            style=filled;
            fillcolor="#bbdefb";

            range_diff_cmd [label="git range-diff --no-color --no-notes\n  onto..original_head\n  onto..new_head\n\n1 subprocess call. Git does the\ncommit matching for us."];
            parse_range_diff [label="parse_range_diff_output()\n→ Vec<CommitMapping>"];
            mapping_kind [label="Per-line output:\n  = Identical (copy note)\n  ! Modified (hunk transfer)\n  < Deleted (no-op)\n  > Added (no-op)", shape=note, fillcolor="#90caf9"];
        }

        v3_entry -> range_diff_cmd;
        range_diff_cmd -> parse_range_diff;
        parse_range_diff -> mapping_kind [style=dotted];

        // =============================================
        // STEP 2: SQUASH DETECTION
        // =============================================
        subgraph cluster_squash_detect {
            label="Step 2: Squash Detection";
            style=filled;
            fillcolor="#fff3e0";

            squash_detect [label="detect_squash_groups(mappings)\n\nPattern: consecutive < (Deleted)\nfollowed by ! (Modified) or > (Added)\n→ SquashGroup { all originals, new }"];
            squash_decision [label="Is this commit\npart of a squash?", shape=diamond, fillcolor="#ffe0b2"];
        }

        parse_range_diff -> squash_detect;
        squash_detect -> squash_decision;

        // =============================================
        // STEP 3: PER-MAPPING DISPATCH
        // =============================================
        subgraph cluster_dispatch {
            label="Step 3: Per-Mapping Attribution Transfer";
            style=filled;
            fillcolor="#c8e6c9";

            case_identical [label="Identical (=)\ncopy_note(original, new)\n\nJust remap SHA.\nFastest path.", fillcolor="#e8f5e9"];

            case_modified [label="Modified (!)\ntransfer_attribution_via_diff(\n  original, new\n)\n\n1:1 hunk transfer.", fillcolor="#fff9c4"];

            case_squash [label="Squash (N:1)\ntransfer_attribution_squash(\n  all_originals[], new\n)\n\nDiff against EACH original,\nUNION transferred attributions.", fillcolor="#fff3e0"];

            case_deleted [label="Deleted (<)\nno-op\n\nCommit dropped →\nattribution dropped.", fillcolor="#ffebee"];

            case_added [label="Added (>)\nno-op\n\nNew commit. Attribution\nfrom post-commit flow.", fillcolor="#f3e5f5"];
        }

        squash_decision -> case_identical [label="= mapping"];
        squash_decision -> case_modified [label="! not in\nsquash group"];
        squash_decision -> case_squash [label="! or > in\nsquash group"];
        squash_decision -> case_deleted [label="< standalone"];
        squash_decision -> case_added [label="> not in\nsquash group"];

        // =============================================
        // STEP 4: HUNK-LEVEL ATTRIBUTION TRANSFER
        // (shared by Modified and Squash)
        // =============================================
        subgraph cluster_hunk_transfer {
            label="Step 4: diff_based_line_attribution_transfer()\n(core algorithm — imara-diff)";
            style=filled;
            fillcolor="#fff8e1";

            load_note [label="repo.notes_show(refs/notes/ai, original)\n→ AuthorshipLog"];
            get_blobs [label="cat_file_content(sha:path)\nfor each attested file\n\n(old content + new content)"];

            subgraph cluster_hunk_ops {
                label="Walk diff hunks (imara-diff):";
                style=filled;
                fillcolor="#ffecb3";

                hunk_equal [label="Equal (context)\n→ attribution COPIED\nat new line positions"];
                hunk_delete [label="Delete (-)\n→ attribution REMOVED"];
                hunk_insert [label="Insert (+)\n→ NO attribution transferred\n(new content, unattributed)"];
                hunk_replace [label="Replace\n→ old attribution REMOVED\n→ new lines unattributed"];
            }

            build_note [label="build new AuthorshipLog\nwith transferred attestations\n+ preserved metadata (prompts, sessions)"];
            write_note [label="repo.notes_add(\n  refs/notes/ai, new_sha, content\n)"];
        }

        case_modified -> load_note;
        case_squash -> load_note [label="for EACH\noriginal"];
        load_note -> get_blobs;
        get_blobs -> hunk_equal;
        get_blobs -> hunk_delete;
        get_blobs -> hunk_insert;
        get_blobs -> hunk_replace;
        hunk_equal -> build_note;
        hunk_delete -> build_note;
        hunk_insert -> build_note;
        hunk_replace -> build_note;
        build_note -> write_note;

        case_identical -> write_note [label="copy note\nas-is"];

        // =============================================
        // STEP 5: WORKING LOG MIGRATION
        // =============================================
        subgraph cluster_wl {
            label="Step 5: Working Log Migration";
            style=filled;
            fillcolor="#e0f2f1";

            wl_check [label="has_working_log(original_head)?", shape=diamond, fillcolor="#b2dfdb"];
            wl_rename [label="rename_working_log(\n  original → new\n)"];
            wl_merge [label="merge INITIAL attrs\nfrom old into new\ndelete old"];
        }

        write_note -> wl_check [style=invis];
        wl_check -> wl_rename [label="new doesn't exist\n(simple rename)"];
        wl_check -> wl_merge [label="both exist\n(merge INITIAL only)"];
    }

    triple -> v3_entry [penwidth=2, color="#1565c0"];

    // =============================================
    // PERFORMANCE
    // =============================================
    subgraph cluster_perf {
        label="Performance (≤50% of native git time)";
        style=filled;
        fillcolor="#efebe9";

        perf [label="Total subprocess calls:\n\n1. git range-diff (1 call)\n2. git notes show (1 per original with note)\n3. git cat-file (1 per file per modified pair)\n4. git notes add (1 per new commit)\n\nNo reflog parsing. No ancestry validation.\nNo merge-base computation (beyond onto).\nNo blame fallback. No rewrite_log I/O.", shape=note, fillcolor="#d7ccc8"];
    }

    // =============================================
    // WHAT'S ELIMINATED
    // =============================================
    subgraph cluster_eliminated {
        label="ELIMINATED (~5000 lines)";
        style="filled,dashed";
        fillcolor="#ffebee";
        color="#c62828";

        elim_rewrite_log [label="rewrite_log.rs (710 lines)\nJSONL event persistence\nMAX_EVENTS trimming\nEvent type dispatch", fillcolor="#ffcdd2", style="rounded,filled,dashed"];
        elim_rebase_auth [label="rebase_authorship.rs (4782 lines)\n5 separate rewrite functions\nload_rebase_note_cache\nVirtualAttributions fallback\npair_commits_for_rewrite\ntry_fast_path_remap", fillcolor="#ffcdd2", style="rounded,filled,dashed"];
        elim_rebase_hooks [label="rebase_hooks.rs (166 lines)\nbuild_rebase_commit_mappings\noriginal_equivalent_for_rewritten\nwalk_commits_to_base", fillcolor="#ffcdd2", style="rounded,filled,dashed"];
        elim_daemon_state [label="Daemon state (~500 lines)\npending_rebase_original_head\npending_cherry_pick_sources\nconflict/abort/continue tracking\nrewrite event synthesis\napply_rewrite_side_effect()", fillcolor="#ffcdd2", style="rounded,filled,dashed"];
        elim_segment [label="Segment resolution (~300 lines)\nstable_rebase_heads_from_worktree\nresolve_rebase_segment_for_worktree\nprocessed_rebase_new_heads\nresolve_explicit_rebase_branch_ref", fillcolor="#ffcdd2", style="rounded,filled,dashed"];
    }

    // =============================================
    // INVARIANTS
    // =============================================
    subgraph cluster_invariants {
        label="Design Invariants";
        style=filled;
        fillcolor="#e8eaf6";

        inv1 [label="1. Hunk attribution:\n   COPIED → preserved at new positions\n   DELETED → removed\n   INSERTED → no attribution (new content)", shape=note, fillcolor="#c5cae9"];
        inv2 [label="2. Squash (N:1):\n   Diff against ALL originals, UNION attrs.\n   No attribution loss from non-matched originals.", shape=note, fillcolor="#c5cae9"];
        inv3 [label="3. Conflict resolution:\n   Not handled here. Normal post-commit flow.\n   AI agent checkpoints → post_commit() as usual.", shape=note, fillcolor="#c5cae9"];
        inv4 [label="4. Stateless:\n   No rewrite_log. No pending state.\n   Stash SHA from trace2 ref-changes.\n   Squash source from git state.", shape=note, fillcolor="#c5cae9"];
        inv5 [label="5. Performance:\n   wall_time(v3) ≤ 0.5 × wall_time(native_git)\n   Dominated by range-diff + N cat-files.", shape=note, fillcolor="#c5cae9"];
    }
}
